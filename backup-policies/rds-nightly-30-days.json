{
   "plans":{
      "PAD-RDS-Nightly-Backup-Plan":{
         "regions":{
            "@@append":[
               "eu-west-1"
            ]
         },
         "rules":{
            "Nightly-30-Day-Rule":{
               "schedule_expression":"cron(0 2 * * ? *)",
               "start_window_minutes":60,
               "completion_window_minutes":180,
               "lifecycle":{
                  "delete_after_days":30
               },
               "target_backup_vault_name":"Default"
            }
         },
         "selections":{
            "tags":{
               "PAD-Databases":{
                  "iam_role_arn":"arn:aws:iam::$account:role/aws-service-role/backup.amazonaws.com/AWSServiceRoleForBackup",
                  "tag_key":"Environment",
                  "tag_value":[
                     "Production",
                     "Non-Production"
                  ]
               }
            }
         }
      }
   }
}
