{
  "plans": {
    "PAD-RDS-Nightly-Backup-Plan": {
      "regions": {
        "@@append": [
          "eu-west-1"
        ]
      },
      "rules": {
        "Nightly-30-Day-Rule": {
          "schedule_expression": {
            "@@assign": "cron(0 2 * * ? *)"
          },
          "start_window_minutes": {
            "@@assign": "60"
          },
          "completion_window_minutes": {
            "@@assign": "180"
          },
          "lifecycle": {
            "delete_after_days": {
              "@@assign": "30"
            }
          },
          "backup_vault_name": {
            "@@assign": "Default"
          }
        }
      },
      "selections": {
        "tags": {
          "PAD-Databases": {
            "iam_role_arn": {
              "@@assign": "arn:aws:iam::$account:role/aws-service-role/backup.amazonaws.com/AWSServiceRoleForBackup"
            },
            "tag_key": {
              "@@assign": "Environment"
            },
            "tag_value": {
              "@@assign": [
                "Production",
                "Non-Production"
              ]
            }
          }
        }
      }
    }
  }
}
