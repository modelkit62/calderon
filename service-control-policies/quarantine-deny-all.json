{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DenyAllExceptAdminsAndSecurity",
      "Effect": "Deny",
      "Action": "*",
      "Resource": "*",
      "Condition": {
        "ArnNotLike": {
          "aws:PrincipalARN": [
            "arn:aws:iam::*:role/AWSControlTowerExecution",
            "arn:aws:iam::*:role/aws-controltower-ForwardSnsNotificationRole",
            "arn:aws:iam::*:role/aws-reserved/sso.amazonaws.com/*/AWSReservedSSO_AdministratorAccess_*",
            "arn:aws:iam::*:role/aws-reserved/sso.amazonaws.com/*/AWSReservedSSO_SecurityAuditor_*"
          ]
        }
      }
    }
  ]
}
