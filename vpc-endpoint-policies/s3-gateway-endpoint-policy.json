{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "Access-to-specific-Org-only",
      "Effect": "Allow",
      "Principal": "*",
      "Action": "*",
      "Resource": "*",
      "Condition": {
        "StringEquals": {
          "aws:PrincipalOrgID": "${aws:PrincipalOrgID}"
        }
      }
    }
  ]
}
